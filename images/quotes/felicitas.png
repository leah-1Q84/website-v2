to max-w-[1168px]\",\"children\":[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L3\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}]}]]\n"])</script><script>self.__next_f.push([1,"7:[\"$\",\"div\",null,{\"children\":\"Content not found \"}]\n"])</script><script>self.__next_f.push([1,"c:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n"])</script><script>self.__next_f.push([1,"10:I[65643,[\"/_next/static/chunks/13483537b1ed8dbf.js\",\"/_next/static/chunks/b179af0a463aed5c.js\"],\"default\"]\n13:I[45872,[\"/_next/static/chunks/13483537b1ed8dbf.js\",\"/_next/static/chunks/b179af0a463aed5c.js\",\"/_next/static/chunks/45b8ed539d404aec.js\",\"/_next/static/chunks/df195cd869e8e942.js\"],\"Header\"]\n11:T447,Die wichtigste Voraussetzung ist eine funktionierende Internetabdeckung, damit die Scans verlässlich beim Awareness-Team eintreffen. Abhängig davon braucht ihr als Bereitsteller*innen von saferspaces lediglich ein Tablet (empfohlen) oder Telefon, um die eingehenden Fälle zu koordinieren. Neben der Anwendung können wir Euch gern auch bei der Infrastruktur und Bereitstellung der Hardware behilflich sein. Das gesamte System setzt sich aus drei Komponenten zusammen: Die Verwaltung, in der die Codes für den Anlass generiert werden und die gewünschten Funktionen (Chat, Standortfreigabe, Notfallnummer …) hinterlegt werden können. Einer App für die Awareness Teams, in der die Vorfälle eingehen und koordiniert werden. Den Codes für die Besuchenden und Mitarbeitenden für das Melden von unsicheren Situationen. Nebst der Technik ist es entscheidend, dass die Menschen, die die entsprechenden Fälle annehmen, im Umgang mit Betroffenen geschult sind. Wenn hier eine Schulung oder Fortbildung benötigt oder gewünscht wird, verbinden wir Euch gern mit den entsprechenden Initiativen."])</script><script>self.__next_f.push([1,"4:[\"$\",\"$L10\",null,{\"namespaces\":[\"translations\",\"seo\",\"legals\"],\"lang\":\"assets\",\"resources\":{\"de\":{\"translations\":{\"common\":{\"app_title\":\"saferspaces - Für ein respektvolles Miteinander\",\"name_de\":\"Deutsch\",\"name_en\":\"Englisch\",\"de_flag\":\"Flagge von Deutschland\",\"en_flag\":\"Flagge von Großbritannien\",\"flag_one\":\"Flagge\",\"flag_other\":\"Flaggen\",\"variables\":\"{{ count }} flags for {{ user }}\",\"navigation\":{\"appointment\":\"Demo buchen\",\"appointment_variation_1\":\"Termin buchen\",\"login\":\"Login\",\"imprint\":\"Impressum\",\"privacy\":\"Datenschutz\",\"faq\":\"FAQ\",\"accessibility\":\"Barrierefreiheit\",\"agb\":\"AGB\",\"termination\":\"Kündigung\",\"menu\":{\"open\":\"Navigationsmenü öffnen\",\"close\":\"Navigationsmenü schließen\"},\"carousel\":{\"navigation\":\"Karussell-Navigation\",\"goToItem\":\"Zu Element {{index}} von {{total}}\",\"currentItem\":\"Element {{index}} von {{total}}, aktuell ausgewählt\"},\"home\":{\"title\":\"Unser Ansatz\",\"direct\":\"Features\",\"useCases\":\"Anwendungsbereiche\",\"advantages\":\"Vorteile\",\"customers\":\"Unsere Kunden\"},\"business\":{\"title\":\"Für Kunden\",\"pricing\":\"Preise\",\"mustHaves\":\"Vorraussetzungen\",\"setup\":\"Setup\",\"projects\":\"Projekte\",\"impact\":\"Impact\",\"feedback\":\"Feedback\",\"menu\":[]},\"about\":{\"title\":\"Über uns\",\"how-to-start\":\"Umsetzung\",\"admin\":\"Buchungssystem\",\"price\":\"Preise\"},\"impact\":{\"title\":\"Wirkung\",\"how-to-start\":\"Umsetzung\",\"admin\":\"Buchungssystem\",\"price\":\"Preise\"}}},\"consent\":{\"banner\":{\"title\":\"Hilf uns, die Website zu verbessern\",\"body\":\"Wir erfassen optionale Analysedaten, um zu verstehen, wie unsere Seite genutzt wird. Du kannst jederzeit zustimmen oder ablehnen.\",\"accept\":\"Erlauben\",\"decline\":\"Ablehnen\",\"manage\":\"Auswahl verwalten\",\"privacyLink\":\"Datenschutzerklärung\",\"cookieLink\":\"Cookie-Richtlinie\"},\"settings\":{\"currentStatus\":\"Aktuelle Einstellung:\",\"status\":{\"accepted\":\"Akzeptiert\",\"declined\":\"Abgelehnt\",\"notSet\":\"Nicht gesetzt\"},\"analytics\":{\"accept\":\"Akzeptieren\",\"decline\":\"Ablehnen\"}},\"saved\":\"Einstellung gespeichert\"},\"pricing\":{\"wizard\":{\"back\":\"Zurück\",\"progressIndicator\":{\"label\":\"Fortschrittsanzeige\",\"step\":\"Schritt {{current}} von {{total}}\",\"progress\":\"{{progress}}% abgeschlossen\"}}},\"home\":{\"hero\":{\"title\":\"Einfach, sicher, \u003cbr /\u003e für \u003cem\u003ealle\u003c/em\u003e\",\"subtitle\":\"Saferspaces macht Sicherheit zugänglich – niedrigschwellig, anonym und in Echtzeit. Für Veranstaltungen, Städte und Organisationen.\"},\"logos\":{\"title\":\"\u003cem\u003eVertrauen\u003c/em\u003e bereits auf uns\"},\"digitalAwarenessApproach\":{\"title\":\"Da sein, wenn \u003cem\u003eHilfe\u003c/em\u003e gebraucht wird\",\"text\":\"Wir verbinden Schutz und Wohlbefinden in einer integrierten Sicherheitslösung. Echtzeit-Meldungen machen Hilfe unmittelbar erreichbar, kleine Teams agieren flächendeckend. Mit saferspaces entsteht von der ersten Meldung bis zur strategischen Auswertung ein transparenter, steuerbarer Prozess. \u003cbr /\u003e\u003cbr /\u003eMehr Sicherheit. Mehr Vertrauen. Mit System.\",\"accessibility\":{\"slideshow-3\":\"Menschen tanzen und feiern vor einer Bühne mit Lichtern auf einem Musikfestival in einem Zelt.\",\"poster\":\"Plakat an Metallwand mit Text: \\\"Brauchst du oder jemand anderes Hilfe?\\\" und QR-Code unten rechts.\"}},\"forARespectfulSociety\":{\"title\":\"\u003cem\u003eDaten\u003c/em\u003e, die verändern\",\"text\":\"Mit saferspaces kommt Hilfe genau dort an, wo sie gebraucht wird. Gleichzeitig entstehen präventive Strukturen und wertvolle, datengestützte Erkenntnisse, die eure Sicherheitskonzepte nachhaltig verändern und stärken.\",\"medicalIncident\":{\"title\":\"Medizinische Vorfälle\",\"description\":\"Bei medizinischen Notfällen ermöglicht die ortsbasierte Meldung wertvolle Zeitersparnisse.\"},\"discrimination\":{\"title\":\"Diskriminierung\",\"description\":\"Bei Diskriminierung ist schnelle Unterstützung entscheidend, um Betroffene zu schützen, Situationen zu deeskalieren und Ausgrenzung nicht unwidersprochen zu lassen.\"},\"sexualAssault\":{\"title\":\"Sexuelle \u003cbr/\u003e Übergriffe\",\"description\":\"Bei sexuellen Übergriffen ist der Zugang zu sicherer, diskreter Unterstützung ein zentraler Bestandteil wirksamer Schutzkonzepte.\"},\"generalIncidents\":{\"title\":\"Inklusion und Zugehörigkeit\",\"description\":\"Saferspaces stärkt Inklusion und Zugehörigkeit, indem unterschiedliche Bedürfnisse berücksichtigt und Unterstützung bei Barrieren oder akuten Belastungssituationen zugänglich macht.\"},\"abuseOfPower\":{\"title\":\"Machtmissbrauch\",\"description\":\"In Fällen von Machtmissbrauch oder der Ausnutzung von Autoritäten können Betroffene mit saferspaces, ohne Sorge vor persönlichen Nachteilen beispielsweise im Arbeitskontext, Vorfälle anonym melden und Unterstützung erhalten.\"},\"escalationsOfViolence\":{\"title\":\"Gewalteskalationen\",\"description\":\"Durch die ortsgebundene Meldeoption in Echtzeit wird eine schnelle Reaktion ermöglicht, um Betroffene zeitnah zu unterstützen und kritische Situationen frühzeitig zu deeskalieren.\"},\"notification\":{\"title\":\"Meldefunktion\",\"description\":\"Auch wenn kein Team vor Ort ist, können Besuchende über die Anwendung externe Hilfsangebote einsehen und anonyme Hinweise an die Veranstaltenden übermitteln.\"}},\"onsiteQrResponse\":{\"title\":\"\u003cem\u003eAnonym\u003c/em\u003e und \u003cbr /\u003e \u003cem\u003eniedrigschwellig\u003c/em\u003e\",\"text\":\"Die Kontaktaufnahme funktioniert ohne App, ohne Login und damit anonym. Mit wenigen Klicks gelangen Menschen zur passenden Unterstützung. Sicher und zielgerichtet.\u003cbr /\u003e\u003cbr /\u003e Genau deshalb setzen immer mehr Organisationen auf saferspaces, wenn es um professionelle Awareness- und Sicherheitsstrukturen geht.\",\"accessibility\":{\"mockup\":\"Eine Hand hält ein Smartphone. Auf dem Display ist die saferspaces WebApp geöffnet. Oben steht 'Wir sind für dich da'. Da drunter sind drei Auswahlmöglichkeiten: 1. Ich bin Betroffene*r, 2. Ich bin Boebachter*in, 3. Direkt anrufen.\",\"slideshow-2\":\"Smartphone-Bildschirm mit einer deutschen Chat-Unterhaltung über einen Freund, der Unterstützung benötigt, mit schneller Antwort vom Team.\"}},\"features\":{\"title\":\"\u003cem\u003eInnovative\u003c/em\u003e Funktionen\",\"description\":\"Über QR-Codes mit Standortübermittlung, standortunabhängige Venue-Links oder Whitelabel-App-Integrationen ermöglicht saferspaces schnelle und anonyme Unterstützung, ergänzt durch datenschutzkonforme Auswertungen. Die innovativen Funktionen unserer Software lassen sich flexibel anpassen und optimal auf jeden Nutzungskontext ausrichten.\",\"geoPosition\":{\"title\":\"Direkte Standortübermittlung\",\"description\":\"Automatische Standortübermittlung in Echtzeit ermöglichen Zielgerichtete Hilfe, genau dort wo sie gebraucht.\"},\"anonymous\":{\"title\":\"Anonymes Melden\",\"description\":\"Die Kontaktaufnahme kann anonym ohne die Erfassung von personenbezogenen Daten erfolgen.\"},\"noApp\":{\"title\":\"Kein Download einer App\",\"description\":\"Ohne App-Download und ohne Registrierung: Saferspaces ist direkt über den Browser erreichbar und ermöglicht einen schnellen Zugang zu Unterstützung.\"},\"easyContact\":{\"title\":\"Einfache Kontaktaufnahme\",\"description\":\"Unser System senkt die Hürden, in herausfordernden Situationen Hilfe anzufordern, diskret und niedrigschwellig.\"},\"documentation\":{\"title\":\"Protokollfunktion\",\"description\":\"Die integrierte Protokollfunktion ermöglicht eine strukturierte Dokumentation und unterstützt die kontinuierliche Optimierung von Prozessen sowie eine professionelle Nachbereitung.\"},\"geoFencing\":{\"title\":\"Geofencing\",\"description\":\"Durch das Aktivieren der Geofencing-Funktion erkennt das System, ob sich die meldende Person im Nutzungskontext befindet.\"},\"data\":{\"title\":\"Erfassung von Metadaten\",\"description\":\"Essenziell ist die Erfassung relevanter Metadaten, die im kundeneigenen Analyse-Dashboard aufbereitet werden, um präventive Maßnahmen zu stärken und Muster frühzeitig zu erkennen.\"},\"whtieLabel\":{\"title\":\"White Label\",\"description\":\"Die Whitelabel-Lösung ermöglicht eine Nutzung im eigenen Erscheinungsbild und stärkt Identifikation, Wiedererkennung und Vertrauen bei den Besuchenden.\"},\"language\":{\"title\":\"Automatisierte Mehrsprachigkeit\",\"description\":\"Automatisierte Mehrsprachigkeit schafft einen inklusiven Zugang, indem sich die Anwendung an der Browsersprache orientiert und Sprachbarrieren abbaut.\"},\"integration\":{\"title\":\"Standortunabhängige Lösung\",\"description\":\"Neben standortbezogenen QR-Codes auf Plakaten ermöglichen unkomplizierte App-Integrationen sowie kundeneigene Venue-Links direkte Meldungen von jedem Standort, zu jeder Zeit.\"},\"reporting\":{\"title\":\"Meldetool\",\"description\":\"Wenn sich eine Person über den Venue-Link meldet und sich nicht im Nutzungskontext aufhält, kann über das Melde-Tool jederzeit eine anonyme Mitteilung erfolgen.\"}},\"highlights\":{\"title\":\"Besondere \u003cem\u003eHighlights\u003c/em\u003e\",\"items\":{\"rapidResponse\":{\"title\":\"Rapid Response\",\"subtitle\":\"Einfach. Direkt. Wirksam.\",\"description\":\"Unser Rapid-Response-System sorgt dafür, dass Hilfe schnell, zielgerichtet und ohne Umwege genau dort ankommt, wo sie gebraucht wird.\",\"alt\":\"Zwei Screenshots: Benachrichtigung über Belästigung in WC D, Kabine 2 rechts; Chat zeigt Hilfsangebot und Nachfrage nach weiteren Infos.\"},\"heatmap\":{\"title\":\"Heatmap\",\"subtitle\":\"Erkennen, wo am meisten Hilfe benötigt wird.\",\"description\":\"Die Heatmap zeigt auf einen Blick, wo Unterstützung besonders häufig benötigt wird – und macht Muster sichtbar, die sonst verborgen bleiben.\",\"alt\":\"Karte mit roten Markierungen und Heatmap, zeigt Alarm-Standorte rund um die Fritz-Schupp-Allee in einem Wohngebiet.\"},\"dataAnalysis\":{\"title\":\"Datenauswertung\",\"subtitle\":\"Klare Übersicht aller relevanten Daten.\",\"description\":\"Das Analyse-Dashboard macht die Systemwirksamkeit sichtbar und liefert Daten für eine nachhaltige Verbesserung der Sicherheitslage.\",\"alt\":\"830 Scans, 23 Meldungen, 23 Protokolle; Vorfallarten und Sprachen: Deutsch 19, Englisch 4, Überkonsum 6, Angriff 4.\"},\"rapidReport\":{\"title\":\"Rapid Report\",\"subtitle\":\"Vertraulich melden. Jeder Zeit.\",\"description\":\"Auch wenn kein Team im Einsatz ist, bleibt unser System wirksam. Über das Rapid Reporting können Meldungen jederzeit und von jedem Standort anonym und in Echtzeit an verantwortliche Stellen übermittelt werden.\",\"alt\":\"Formular mit Textfeld für eine Nachricht, Buttons „Jetzt anonym melden“ und „Kontaktdaten hinterlassen“.\"},\"geofencing\":{\"title\":\"Geofencing\",\"subtitle\":\"Bestimme, wo Rapid Response aktiv ist.\",\"description\":\"Das Geofencing ermöglicht eine gezielte Nutzung innerhalb klar definierter Bereiche. So wird sichergestellt, dass Meldungen nur dort erfolgen, wo entsprechende Strukturen und Zuständigkeiten vorhanden sind.\",\"alt\":\"Zwei Kreise mit den Texten „Rapid Response“ und „Rapid Report“ auf einer stilisierten Karte bei Uwe-Seeler-Allee.\"},\"whiteLabel\":{\"title\":\"White Label\",\"subtitle\":\"Nahtlos in eure Systeme integrierbar.\",\"description\":\"Saferspaces lässt sich nahtlos als Whitelabel-Lösung integrieren – so können Organisationen alle Funktionen unter ihrem eigenen Branding anbieten, ohne Einschränkungen in Nutzung oder Zugänglichkeit.\",\"alt\":\"OMR-Logo und Name in weißem Schriftzug auf einem schwarzen Hintergrund. „For a respectful togetherness“ in großen Buchstaben.\"}}},\"customerFeedback\":{\"title\":\"Was unsere \u003cem\u003eKunden\u003c/em\u003e \u003cbr /\u003e über uns sagen\",\"description\":\"Unsere Anwendung ist seit 2021 im Nachtleben, im Profisport, bei Großveranstaltungen, in Unternehmen und vielen weiteren Orten erfolgreich für ein respektvolleres Miteinander im Einsatz.\",\"imageAriaLabel\":\"Foto von: {{name}}, {{position}} {{company}}\"},\"contact\":{\"title\":\"Jetzt \u003cem\u003eDemo\u003c/em\u003e \u003cbr /\u003e buchen\",\"description\":\"Jetzt kostenlosen Termin buchen. Wir zeigen euch in wenigen Minuten, wie saferspaces eure Awareness- und Sicherheitsstrukturen einfach und wirksam stärken kann.\",\"accessibility\":{}}},\"highlights\":{\"open\":\"Beschreibung für {{title}} öffnen\",\"close\":\"Beschreibung für {{title}} schließen\"},\"business\":{\"hero\":{\"title\":\"Ein System, das \u003cem\u003eSicherheit\u003c/em\u003e neu definiert\",\"subtitle\":\"Saferspaces macht innovative Sicherheitskonzepte sichtbar, messbar und wirksam\"},\"safer\":{\"title\":\"Einfach. Modern. Wirkungsvoll.\",\"text\":\"Unser System hilft euch, kritische Situationen frühzeitig zu erkennen und strukturiert zu bearbeiten. Saferspaces passt sich flexibel jedem Kontext an, steigert die Zufriedenheit eurer Besuchenden und liefert wertvolle Daten, um Sicherheits- und Awarenessstrukturen langfristig zu verbessern.\",\"accessibility\":{\"slideshow-1\":\"Blick ins Stadion mit grünem Spielfeld, Tribünen und blauem Hilfeposter mit Text 'DO YOU OR DOES SOMEONE ELSE NEED HELP?'\",\"slideshow-2\":\"Runder Button mit Text „Brauchst du oder jemand anders Hilfe?“ an einer lila Tasche befestigt.\",\"slideshow-3\":\"Banner mit Text: „Für ein respektvolles Miteinander auf der Kieler Woche“, QR-Code und Handy mit App auf hellem Hintergrund.\",\"slideshow-4\":\"Lila Bildschirme mit Text „AWARENESS AT #OMR25“, Fotos von zwei Personen und QR-Code für Safer Spaces.\",\"slideshow-5\":\"Bühne mit „RSH Kindertag“-Banner und großem Bildschirm: „Brauchst du oder jemand anders Hilfe?“ plus QR-Code.\",\"slideshow-6\":\"Blauer Flyer mit „Schutzkonzept im Stadion“ vor Stadion und buntem „Munich“-Banner bei bewölktem Himmel.\"}},\"benefits\":{\"title\":\"Messbarer \u003cem\u003eMehrwert\u003c/em\u003e\",\"text\":\"Saferspaces stärkt das Angebot von Veranstaltenden und Organisationen, erweitert Zielgruppen und verbessert die Besuchendenerfahrung durch innovative, zugängliche und zukunftsorientierte Sicherheitsstrukturen.\",\"items\":{\"costs\":{\"title\":\"Reduziert Kosten\",\"description\":\"Unser System reduziert Kosten durch schnelle Reaktionen, verhinderte Sanktionen und den effizienteren Einsatz von Sicherheits- und Personalkapazitäten.\"},\"data\":{\"title\":\"Liefert wertvolle Daten\",\"description\":\"Wertvolle, anonymisierte Daten, helfen dabei, Sicherheits- und Safeguarding-Strukturen gezielt weiterzuentwickeln.\"},\"standards\":{\"title\":\"Erhöht die Standards\",\"description\":\"Mit Saferspaces werden bestehende Strukturen systematisch gestärkt, weiterentwickelt und zukunftsorientiert ausgerichtet.\"},\"security\":{\"title\":\"Stärkt das Sicherheitsempfinden\",\"description\":\"Die Implementierung von Saferspaces wirkt sich positiv auf das Sicherheitsempfinden von Besuchenden aus.\"},\"escalation\":{\"title\":\"Mindert das Eskalationsrisiko\",\"description\":\"Das System unterstützt die frühzeitige Intervention und mindert so das Eskalationsrisiko.\"},\"team\":{\"title\":\"Senkt die Fluktuation\",\"description\":\"Saferspaces schafft verlässliche Strukturen, die das Wohlbefinden von Mitarbeitenden fördern und Fluktuation entgegenwirken.\"},\"revenue\":{\"title\":\"Erweitert Zielgruppen\",\"description\":\"Die Integration unserer Meldestruktur hilft dabei, neue Zielgruppen zu erschließen und schafft so die Grundlage für steigende Einnahmen.\"}}},\"setup\":{\"title\":\"Sofort \u003cem\u003eeinsatzbereit\u003c/em\u003e\",\"text\":\"Die Einrichtung der Anwendung erfolgt schnell und mit minimalem Aufwand.\",\"steps\":[{\"title\":\"Check-in\",\"description\":\"Bei einem kurzen Check-in teilt ihr uns mit, in welchem Kontext saferspaces eingesetzt werden soll und wir schauen gemeinsam, ob die Must-Haves für die Nutzung gegeben sind.\",\"content\":\"content\"},{\"title\":\"Aufsetzen der Infrastruktur\",\"description\":\"Im zweiten Schritt richten wir das Projekt ein, stellen die Druckdateien bereit und vergeben die Zugänge zum Meldesystem sowie dem Analyse Dashboard.\",\"content\":\"content\"},{\"title\":\"Onboarding und Live-Test\",\"description\":\"In einem kurzen Onboarding erhalten die zuständigen Teams eine Einweisung in die Nutzung der Anwendung. Anschließend kann Saferspaces direkt eingesetzt werden.\",\"content\":\"content\"},{\"title\":\"Platzieren und Live-Test vor Ort\",\"description\":\"Um die standortbezogenen Meldungen zu ermöglichen werden die Plakate im Vorfeld platziert und  positioniert. In komplexeren Kontexten ermöglichen wir zudem einen Live-Test vor Ort für einen reibungslosen Start.\",\"content\":\"content\"}]},\"mustHaves\":{\"title\":\"\u003cem\u003eMust-haves\u003c/em\u003e für \u003cbr /\u003edie Nutzung\",\"text\":\"Um saferspaces erfolgreich einzusetzen, braucht es einzelne Grundvoraussetzungen, die sicherstellen, dass die Betreuung von Betroffenen bestmöglich umgesetzt wird. Weitere Infos dazu, wie unsere Anwendung ideal eingesetzt wird findest du \u003c2\u003ehier\u003c/2\u003e.\",\"imageAlt\":\"Weißer Container mit bunter Grafik und Text 'AWARENESS SPACE' vor einem modernen Gebäude.\",\"steps\":[{\"title\":\"Geschultes Personal\",\"description\":\"Der Einsatz von Personal, das ausschließlich für die Betreuung von Betroffenen vorgesehen ist, ist essentiell.\",\"content\":\"/assets/icons/handshake.svg\"},{\"title\":\"Stabiles Internet\",\"description\":\"Da es sich bei saferspaces um eine webbasierte Software-Anwendung handelt, ist eine stabile Internetverbindung (zumindest für das Personal) die Grundlage für eine erfolgreiche Nutzung.\",\"content\":\"/assets/icons/wifi.svg\"},{\"title\":\"Saferspace\",\"description\":\"Wichtig ist zudem das Vorhandensein eines geeigneten Rückzugsraums für vertrauliche Gespräche und Unterstützung.\",\"content\":\"/assets/icons/awareness.svg\"}]},\"pricing\":{\"nonProfit\":\"Kultur / Non-Profit\",\"from\":\"ab\",\"title\":\"Transparente Preise\",\"text_1\":\"Wir unterstützen Organisationen jeder Größe dabei, sichere und respektvolle Umgebungen zu schaffen. Uns ist bewusst, dass betroffenenorientierte Sicherheits- und Awarenesskonzepte mehr erfordern als eine umfassende technische Infrastruktur. \u003cbr /\u003e\u003cbr /\u003eUnser Preismodell senkt die Einstiegshürde deutlich und stellt sicher, dass Budgets für Personal und Schulungen erhalten bleiben. \u003cbr /\u003e\u003cbr /\u003eSollten dennoch Budgetrestriktionen dennoch eine Herausforderung darstellen, sprecht uns gerne an. \u003cbr /\u003e\u003cbr /\u003e\u003cstrong\u003eJetzt individuellen Preis berechnen. Transparent, passgenau und fair.\u003c/strong\u003e\",\"note\":\"Berechne hier die anfallenden Kosten schnell und unkompliziert.\",\"usage\":\"Nutzung\",\"permanent\":\"Dauerhafte Nutzung\",\"once\":\"Einmalige Nutzung\",\"onboardingCosts\":\"+ Einmalig ab {{ amount }} Setup-Gebühr\",\"capacity\":{\"permanent\":\"Durchschnittliche Auslastung\",\"once\":\"Erwartete Besuchendenzahl\"},\"price\":\"Voraussichtlicher Preis\",\"pricePerMonth\":\"pro Monat (12 Monate Laufzeit)\",\"pricePerYear\":\"pro Jahr (12 Monate Laufzeit)\",\"pricePerYear2\":\"pro Jahr (24 Monate Laufzeit)\",\"pricePerYear3\":\"pro Jahr (36 Monate Laufzeit)\",\"priceNote\":\" Alle Preise verstehen sich zuzüglich 19% MwSt.\",\"getInTouch\":\"Demo buchen\"},\"caseStudies\":{\"title\":\"Unsere \u003cem\u003eKunden\u003c/em\u003e\",\"description\":\"Eingesetzt bei der UEFA EURO 2024 und 2025, dem Reeperbahn Festival, der gamescom, der Allianz Arena, OMR und vielen weiteren: Saferspaces ist ein unverzichtbarer Bestandteil moderner Sicherheits-, Awareness- und Unterstützungskonzepte geworden.\",\"euro2025\":{\"title\":\"UEFA EURO 2025\",\"description\":\"Unser Rapid-Response System war erneut ein fester Bestandteil des Safeguarding-Konzeptes bei der UEFA EURO 2025.\",\"imageAlt\":\"UEFA Women's Euro Switzerland 2025 Logo auf blauem Hintergrund mit Symbolen und pinken Akzenten.\"},\"omr\":{\"title\":\"OMR\",\"description\":\"Bei der OMR ’25 konnte jederzeit und von jedem Standort über Screens oder den Link omr.saferspaces.io Kontakt zum Awareness-Team aufgenommen werden.\",\"imageAlt\":\"Digitale Infotafeln mit lila Hintergrund informieren über Awareness bei #OMR25 und bieten Kontaktmöglichkeiten für Unterstützung.\"},\"barclays\":{\"title\":\"Barclays Arena\",\"description\":\"Seit dem Frühjahr’ 25 bietet auch die Barclays Arena  einen direkten und optional anonymen Kontakt zum Awareness-Team vor Ort.\",\"imageAlt\":\"Barclays Arena mit großem Logo und Schriftzug, modernes Gebäude vor Stadtsilhouette bei blauem Himmel.\"},\"euro2024\":{\"title\":\"UEFA EURO 2024\",\"description\":\"Bei der EURO 2024 ergänzte Saferspaces die Sicherheits-strukturen in Stadien und Fanzones durch einen anonymen, niedrigschwelligen Zugang zu unmittelbarer Unterstützung.\",\"imageAlt\":\"#FOOTBALL, Brauchst du oder jemand anders Hilfe? Vor blauem Hintergrund mit bunten Streifen.\"},\"gamescom\":{\"title\":\"gamescom\",\"description\":\"Auch während der gamescom in Köln konnten Besuchende über unser System jederzeit Kontakt aufnehmen, wenn Hilfe gebraucht wurde.\",\"imageAlt\":\"Publikum sitzt vor einer Bühne mit Lichtern, große Leinwand zeigt „Welcome to gamescom Opening Night Live!“.\"},\"jeremias\":{\"title\":\"Jeremias\",\"description\":\"Jeremias integrierte unser System in ihr Awareness-Konzept, um eine einfache und anonyme Kontaktaufnahme zum Team während und nach den Konzerten zu ermöglichen.\",\"imageAlt\":\"Vier junge Männer (Jeremias) stehen nebeneinander am Meer bei Sonnenuntergang, schauen ernst in die Kamera.\"},\"1fcm\":{\"title\":\"1. FC FC Magdeburg\",\"description\":\"Saferspaces ergänzt die Anlaufstelle am Victoriaplatz um eine anonyme, digitale Meldeoption und ermöglicht einen niedrig-schwelligen Zugang zu Hilfe von jedem Standort.\",\"imageAlt\":\"Text auf blau-grünem Hintergrund: „WO GEHT'S ZUM VIKTORIA-PLATZ? Du fühlst dich bedrängt, belästigt oder hast Gewalt erlebt?“\"},\"fcsp\":{\"title\":\"FC St. Pauli\",\"description\":\"Auch im Millerntor-Stadion des FC St. Pauli kommt saferspaces als Teil des Awareness-Konzeptes zum Einsatz.\",\"imageAlt\":\"Hand hält lila Infoblatt vor dem Eingang des FC St. Pauli Stadions mit großem Vereinslogo und der Aufschrift „1910“.\"},\"csd\":{\"title\":\"CSD Hannover\",\"description\":\"Auch beim CSD Hannover kam unsere Anwendung in diesem Jahr bereits zum zweiten Mal im Einsatz\",\"imageAlt\":\"Brauchst du oder jemand anderes Hilfe? Logo von CSD Hannover oben rechts, SPACESAFER links.\"},\"ksv\":{\"title\":\"Holstein Kiel\",\"description\":\"Holstein Kiel setzt als einer der ersten Vereine der 2. Fußballbundes Liga auf die niedrigschwellige Meldemöglichkeit von Saferspaces.\",\"imageAlt\":\"Blaues Schild mit der Aufschrift: „Brauchst du oder jemand anderes Hilfe?“ und Hinweis zu gegenseitigem Respekt.\"},\"rbf\":{\"title\":\"Reeperbahn Festival\",\"description\":\"Bereits 2022 wurde saferspaces im Rahmen des Awareness-Konzeptes des Reeperbahn Festivals eingesetzt.\",\"imageAlt\":\"Schwarzer Infostand mit lila Banner „AWARENESS POINT“, zwei Personen und einer Tischlampe im Inneren.\"},\"kiwo\":{\"title\":\"Kieler Woche\",\"description\":\"Seit 2023 bietet saferspaces auf dem größten Sommerfest im Norden Europas die Möglichkeit Hilfe anzufordern.\",\"imageAlt\":\"Banner mit Text: „Für ein respektvolles Miteinander auf der Kieler Woche“, QR-Code und Handy mit App „Wir sind bei dir!“.\"},\"rsh\":{\"title\":\"RSH Kindertag\",\"description\":\"Auch beim RSH-Kindertag in Neumünster kam unsere Anwendung zum Einsatz und konnte bei der Zusammenführung zahlreicher Eltern und Kinder effektive Dienste leisten\",\"imageAlt\":\"Bühne beim R.SH-Kindertag mit Publikum, Bannertext: „Wir wünschen viel Spaß beim R.SH-Kindertag“, Hilfehinweis auf Leinwand.\"}},\"impact\":{\"title\":\"Sofort \u003cem\u003ewirksam\u003c/em\u003e. \u003cbr /\u003eLangfristig \u003cem\u003erelevant\u003c/em\u003e.\",\"item1\":{\"title\":\"Inklusiv\",\"description\":\"Der betroffenenorientierter Ansatz schafft Räume, in denen sich alle sicher fühlen und gerne wiederkommen.\"},\"item2\":{\"title\":\"Integrativ\",\"description\":\"Saferspaces ergänzt Sicherheitskonzepte um einen innovativen, zukunftsorientierten Ansatz.\"},\"item3\":{\"title\":\"Informativ\",\"description\":\"Anonymisierte Daten aus jedem Einsatz liefern fundierte Einblicke in den jeweiligen Nutzungskontext.\"}}},\"faq\":{\"hero\":{\"title\":\"\u003cem\u003eFragen\u003c/em\u003e zur Nutzung von saferspaces\",\"subtitle\":\"Solltest du noch weitere Fragen zur Nutzung von saferspaces haben, schreib uns gerne per Mail an kontakt@saferspaces.io\"},\"visitors\":{\"title\":\"Fragen von Besuchenden\",\"questions\":[{\"question\":\"Muss eine besuchende Person für die Nutzung von saferspaces eine App herunterladen?\",\"answer\":\"Unser Ansatz ist es, die Möglichkeit, um Hilfe zu bitten, so niedrigschwellig und anonym wie möglich zu gestalten. Daher braucht ihr als Besuchende lediglich QR-Codes zu scannen, um Kontakt mit dem Awareness-Team aufzunehmen.\"},{\"question\":\"Muss eine besuchende Person ihren Standort freigeben?\",\"answer\":\"Da jeder Code im Saferspaces-System mit einem individuellen Standort hinterlegt ist, brauchen Besuchende keine eigenen Standortinformationen zu übermitteln.\"},{\"question\":\"Was ist, wenn ich mich von dem Code wegbewegen möchte?\",\"answer\":\"Wenn sich eine Person von dem Code wegbewegen möchte, kann die Standortfreigabe innerhalb des Chats freigeschaltet werden. Daraufhin kann das Awareness-Team die betroffene Person auch abseits des Code-Standorts auffinden, um zu helfen.\"},{\"question\":\"Was mache ich, wenn die Kamera im Club oder bei Veranstaltungen abgeklebt wird?\",\"answer\":\"In Kontexten, in denen die Regelung gilt, die Handykameras abzukleben, wird diese Regelung ausschließlich für die Nutzung von Saferspaces aufgehoben.\"},{\"question\":\"Wie erfahre ich als besuchende Person von der Möglichkeit, die Codes zu nutzen?\",\"answer\":\"An allen Orten, an denen saferspaces angeboten wird, findet ihr sowohl im Eingang als auch in den verschiedenen Räumen Beschilderungen, die zum einen auf die Anwendung hinweisen, als auch die Codes abbilden. Einige Clubs arbeiten zudem bereits mit einer Awareness-Ansprache beim Einlass. Das heißt, dass neben den allgemein geltenden Regeln auch das Angebot von saferspaces kurz erläutert wird.\"},{\"question\":\"Muss ich als besuchende Person meine Situation in einem Chat beschreiben?\",\"answer\":\"Der Chat ist lediglich ein Angebot, das du nutzen kannst. Wenn du nichts schreibst, macht sich das Awareness-Team auch ohne eine Nachricht auf den Weg zu dir.\"},{\"question\":\"Was ist der Vorteil von den QR-Codes?\",\"answer\":\"Neben der Tatsache, dass die Codes dir die Option bieten, auch anonym eine Situation zu melden, funktionieren sie zudem wie eine Brücke mit direktem Weg zu den Menschen, die geschult sind, auf kritische Situationen einzugehen und sich Betroffenen anzunehmen. Besuchende müssen nicht fremde Personen ansprechen, in der Hoffnung, diese nicht zu überfordern und die entsprechende Reaktion zu erhalten. Zudem brauchen Besuchende nicht wie bei anderen Ansätzen extra eine App herunterladen und in dem Zuge eine Vielzahl personenbezogener Daten zu übermitteln.\"}]},\"admins\":{\"title\":\"Fragen von Veranstalter:innen\",\"questions\":[{\"question\":\"Kann ich saferspaces auch für einmalige Veranstaltungen nutzen?\",\"answer\":\"Saferspaces kann sowohl einmalig als auch dauerhaft eingesetzt werden. Durch den unkomplizierten und zielgerichteten Ansatz braucht es wenig Vorbereitung, um die Infrastruktur auch kurzfristig zu etablieren. Um sicherzugehen, dass geschultes Personal für die Betreuung möglicher Fälle vor Ort ist, können wir zudem gern bei der Vermittlung von entsprechendem Awareness Personal unterstützen.\"},{\"question\":\"Welche Kosten fallen für mich als Veranstalterin an?\",\"answer\":\"Die Kosten orientieren sich an der maximalen Kapazität des Veranstaltungsorts. Einmalig fällt zudem eine Onboarding-Gebühr an, welche nach dem Aufsetzen dazu dient, das Setting einmal mit den entsprechenden Personen zu testen, letzte Fragen zu klären und sicherzustellen, dass geschultes Personal für die Annahme der Vorfälle und Betreuung von Betroffenen vorhanden sind.\"},{\"question\":\"Was ist der Vorteil von den QR-Codes?\",\"answer\":\"Neben der Tatsache, dass die Codes für Eure Gäst:innen eine sehr niedrigschwellige Möglichkeit der Kontaktaufnahme zu dem Awareness-Personal bieten, haben sie weitere entscheidende Vorteile. Allein durch ihre Anwesenheit im Raum haben die Codes mit den Beschreibungen ihrer Funktion laut ersten Erfahrungsberichten bereits eine positive Wirkung auf die Atmosphäre unter den anwesenden Personen. Die Besuchenden erkennen ein ganzheitliches Sicherheitskonzept und Opportunisten werden von potenziellen Übergriffen im besten Fall abgehalten. Die QR-Codes haben zudem den Vorteil, dass für Besuchende einzig ein mobiles Endgerät genügt, um von dem Konzept zu profitieren. Es muss nicht extra eine App heruntergeladen werden. Um betroffene oder beobachtende Personen aufzufinden brauchen keine Standortinformationen der Gästinnen abgefragt zu werden, da allen Codes individuelle Standorte hinterlegt sind, welche beim Scan an das Team übermittelt werden.\"},{\"question\":\"Welche Infrastruktur brauche ich für die Bereitstellung von saferspaces?\",\"answer\":\"$11\"},{\"question\":\"Wie stelle ich sicher, dass die Meldungen auch tatsächlich gesehen werden?\",\"answer\":\"Wichtig ist, dass mindestens eine Person sich im direkten Umfeld des Endgerätes befindet, welches die eingehenden Fälle aufzeigt. Sobald jemand einen Code scannt, fängt das Display an zu blinken und ein Signalton ertönt für eine Minute, oder bis der Fall angenommen wird.\"},{\"question\":\"Wie kann ich sicher sein, dass die Codes nicht missbräuchlich gescannt werden?\",\"answer\":\"Aus den bisherigen Einsätzen können wir erfreulicherweise berichten, dass es bisher zu keiner einzigen missbräuchlichen Situation im Hinblick auf die Codes gegeben hat. Das hat sowohl mit Beschreibungen auf den Schildern zu tun, als auch mit den einzelnen Steps innerhalb der Anwendung. Nach dem Scan werden die Personen beispielsweise gebeten, noch zu präzisieren, ob es sich um eine beobachtende oder eine betroffene Person handelt. Zudem empfehlen wir eine kurze Ansprache beim Einlass, die sowohl auf den Wunsch eines respektvollen Miteinanders hinweist, und zudem mögliche Konsequenzen, wie ein Hausverbot aufzeigt, sofern sich nicht an die geltenden Regeln gehalten wird.\"},{\"question\":\"Können auch die Mitarbeitenden die Codes nutzen, wenn sie Unterstützung brauchen?\",\"answer\":\"Es ist sogar ein wichtiger Teil unseres Ansatzes, denn viele Augen können besser darauf achten, dass es allen Anwesenden gut geht. Sowohl für eigene Fälle unsicherer Situationen als auch für Situationen, die beobachtet werden, hat das Personal die Möglichkeit, Unterstützung anzufordern. Hier gibt es die Option, sich vor Schichtbeginn über einen Scan einzuloggen und daraufhin nur über einen Button um Hilfe zu bitten. Für Mitarbeitende gibt es zudem zwei Auswahlmöglichkeiten für einen Hilferuf. Zum einen kann eine unsichere Situation gemeldet werden, damit sich eine Person auf den Weg macht, um zu unterstützen. Außerdem gibt es einen Notfall-Button, für Situationen, in denen nicht das Awareness-Team allein gebraucht wird, sondern zudem das Security-Personal unmittelbar zur Hilfe eilen sollte.\"}]},\"prerequisites\":{\"title\":\"Voraussetzungen für die Nutzung\",\"questions\":[{\"question\":\"Welche Voraussetzungen muss das Personal mitbringen?\",\"answer\":\"Im Wesentlichen gibt es überall dort, wo unsere Infrastruktur eingesetzt wird, Menschen, die ausdrücklich für die Unterstützung von Betroffenen im Einsatz sind. Dieses Personal unterscheidet sich vom traditionellen Sicherheitsdienst dadurch, dass es sich nicht darauf konzentriert, wer was getan hat. Die Teams konzentrieren sich auf die Menschen, die von Übergriffen und Diskriminierung betroffen sind, und verlagern den Schwerpunkt darauf, wer betroffen ist und wie man einer hilfesuchenden Person am besten helfen kann.\"},{\"question\":\"Saferspace / Rückzugsraum\",\"answer\":\"Immer dann, wenn eine Person akute seelische Unterstützung benötigt, kann es notwendig sein, einen ruhigen Ort für die Betreuung und Unterstützung der Betroffenen/des Betroffenen anzubieten. Diese Orte sollten im besten Fall geschützt und abseits des Geschehen platziert sein.\"},{\"question\":\"Diverse Teams M/W/D\",\"answer\":\"Eine wichtige Grundvoraussetzung ist zudem, dass die Teams vielfältig aufgestellt sind. Da es im Zusammenhang mit Übergriffen und Diskriminierungen leider häufig betroffene weiblichgelesene Personen gibt, möchten wir sicherstellen, dass in jedem Team mindestens eine weibliche Person im Einsatz ist.\"},{\"question\":\"Mindestalter\",\"answer\":\"Zudem legen wir Wert darauf, dass die Personen, die in der Betroffenenorientierten Arbeit mit saferspaces tätig sind ein Mindestalter von 23 Jahren haben oder über mehrmalige Erfahrungen in der Awareness-Arbeit verfügen.\"},{\"question\":\"Beruflicher Hintergrund\",\"answer\":\"Obwohl es wünschenswert ist, dass die Mitglieder des Awareness-Teams aus dem sozialen, psychologischen oder medizinischen Bereich kommen, ist dies keine zwingende Voraussetzung. Wir legen Wert auf Vielfalt und ermutigen daher auch Personen mit anderen beruflichen Hintergründen, sich im Bereich Awareness weiterzubilden.\"},{\"question\":\"Grundsätzliches\",\"answer\":\"Grundsätzlich empfehlen wir allen Nutzenden von saferspaces über die akute Hilfe von Betroffenen hinaus, sich mit grundlegender Awarenessarbeit im eigenen Kontext zu befassen. Das Ziel sollte es sein, dass Betroffenen sowohl im akut Fall geholfen wird- und zudem auch ein Fokus auf die Ursachen von Diskriminierungen und Übergriffen im eigenen Kontext und auf präventive Maßnahmen gerichtet wird. Wertvolle Informationen in diesem Zusammenhang sind beispielsweise unter folgenden Links zu finden\"}]}},\"caseStudies\":{\"back\":\"Zurück\",\"share\":{\"title\":\"Teilen auf\",\"linkedin\":\"Auf LinkedIn teilen\",\"twitter\":\"Auf Twitter teilen\",\"facebook\":\"Auf Facebook teilen\"},\"metadata\":{\"title\":\"Details\",\"eventDate\":\"Veranstaltungsdatum\",\"readingTime\":\"Lesezeit\",\"location\":\"Standort\",\"locationAvailable\":\"Verfügbar\",\"minute\":\"Min\",\"minutes\":\"Min\",\"client\":\"Kunde\",\"industry\":{\"title\":\"Branche\",\"tourism\":\"Tourismus\",\"sports\":\"Sport\",\"gaming\":\"Gaming\",\"music\":\"Musik\",\"other\":\"Andere\"},\"eventType\":{\"title\":\"Veranstaltungstyp\",\"fair\":\"Messe\",\"festival\":\"Festival\",\"tournament\":\"Turnier\",\"tour\":\"Tour\",\"other\":\"Andere\"}}},\"trustCenter\":{\"systemsReady\":{\"label\":\"Alle Systeme bereit\",\"ariaLabel\":\"Alle Systeme bereit Anzeige\"}},\"altTextGenerator\":{\"dropImageHere\":\"Bild hier ablegen\",\"clickToUpload\":\"Zum Hochladen klicken oder per Drag \u0026 Drop\",\"fileFormats\":\"PNG, JPG, GIF bis zu 10 MB\",\"copyAltText\":\"Alt-Text in die Zwischenablage kopieren\",\"personalInformationWarning\":\"Dieses Bild enthält persönliche Informationen. Bitte entferne sie vor dem Hochladen.\",\"uploadedImageAlt\":\"Hochgeladenes Bild zur Alt-Text-Generierung\",\"verifyPersonalInfo\":\"Prüfe, ob das hochgeladene Bild Gesichter oder andere identifizierende Merkmale enthält. Wenn ja, gib \\\"true\\\" zurück. Wenn nein, gib \\\"false\\\" zurück.\"}},\"seo\":{\"title\":\"Für ein respektvolles Miteinander\",\"description\":\"Saferspaces, eine innovative Softwarelösung für anonyme und unmittelbare Unterstützung in Notlagen durch QR-Code-Scans. Unsere Anwendung verbessert die Sicherheit und fördert ein respektvolles Miteinander in verschiedenen Kontexten.\",\"data\":{\"title\":\"Datenschutzerklärung\",\"description\":\"Datenschutzerklärung von saferspaces - Informationen zum Umgang mit personenbezogenen Daten.\",\"alternates\":{\"canonical\":\"https://www.saferspaces.io/data\",\"types\":{\"de\":\"https://www.saferspaces.io/de/data\",\"en\":\"https://www.saferspaces.io/en/data\"}},\"og\":{\"title\":\"Datenschutzerklärung - Saferspaces\",\"description\":\"Datenschutzerklärung von saferspaces - Informationen zum Umgang mit personenbezogenen Daten.\",\"image\":\"/assets/images/desktop/de:mockup.webp\"},\"twitter\":{\"card\":\"summary\",\"title\":\"Datenschutzerklärung - Saferspaces\",\"description\":\"Datenschutzerklärung von saferspaces - Informationen zum Umgang mit personenbezogenen Daten.\"}},\"faq\":{\"title\":\"Häufig gestellte Fragen zur Nutzung von saferspaces\",\"description\":\"Antworten auf die häufigsten Fragen zur Nutzung von saferspaces, einschließlich Details zur QR-Code-Nutzung, Standortfreigabe, Anonymität und Vorteilen für Besuchende und Veranstalter.\",\"alternates\":{\"canonical\":\"https://www.saferspaces.io/faq\",\"types\":{\"de\":\"https://www.saferspaces.io/de/faq\",\"en\":\"https://www.saferspaces.io/en/faq\"}},\"og\":{\"title\":\"FAQ zur Nutzung von saferspaces\",\"description\":\"Erfahren Sie mehr über die Nutzung von saferspaces, die QR-Codes für schnelle und anonyme Hilfe an Veranstaltungsorten und vielen anderen Kontexten.\",\"image\":\"/assets/images/desktop/de:mockup.webp\"},\"twitter\":{\"card\":\"summary_large_image\",\"title\":\"FAQ zu saferspaces\",\"description\":\"Finden Sie Antworten auf Ihre Fragen zu saferspaces, von QR-Code-Nutzung bis zur Sicherheit bei Veranstaltungen. Lesen Sie mehr in unseren FAQ.\",\"image\":\"/assets/images/desktop/de:mockup.webp\",\"creator\":\"@saferspaces\"}},\"home\":{\"title\":\"Anonyme und niedrigschwellige Hilfe durch QR-Code-Kontakt\",\"description\":\"Saferspaces, eine innovative Softwarelösung für anonyme und unmittelbare Unterstützung in Notlagen durch QR-Code-Scans. Unsere Anwendung verbessert die Sicherheit und fördert ein respektvolles Miteinander in verschiedenen Kontexten.\",\"alternates\":{\"canonical\":\"https://www.saferspaces.io\",\"types\":{\"de\":\"https://www.saferspaces.io/de\",\"en\":\"https://www.saferspaces.io/en\"}},\"og\":{\"title\":\"Saferspaces – Sicherheit und Respekt durch innovative QR-Code-Lösung\",\"description\":\"Saferspaces bietet anonyme, schnelle Hilfe in Notlagen durch einfaches Scannen von QR-Codes. Erfahren Sie mehr über unsere Features und Vorteile.\",\"image\":\"/assets/images/desktop/de:mockup.webp\"},\"twitter\":{\"card\":\"summary_large_image\",\"title\":\"Entdecken Sie Saferspaces – Ihre Sicherheitslösung\",\"description\":\"Mit Saferspaces erhalten Sie unmittelbare Hilfe durch diskrete, anonyme QR-Code-Scans. Sicherheit neu definiert für alle Arten von Veranstaltungen und Einrichtungen.\",\"image\":\"/assets/images/desktop/de:mockup.webp\",\"creator\":\"@saferspaces\"}},\"pricing\":{\"title\":\"Preise – Faire \u0026 transparente Preisgestaltung\",\"description\":\"Konfigurieren Sie Ihr individuelles saferspaces Paket und erhalten Sie sofort eine transparente Preisübersicht. Faire Preise für Clubs, Stadien, Stadtfeste und mehr.\",\"alternates\":{\"canonical\":\"https://www.saferspaces.io/pricing\",\"types\":{\"de\":\"https://www.saferspaces.io/de/pricing\",\"en\":\"https://www.saferspaces.io/en/pricing\"}},\"og\":{\"title\":\"Saferspaces – Faire \u0026 transparente Preise\",\"description\":\"Konfigurieren Sie Ihr individuelles saferspaces Paket in wenigen Schritten. Transparente Preisgestaltung für Clubs, Stadien, Stadtfeste und mehr.\",\"image\":\"/assets/images/desktop/de:mockup.webp\"},\"twitter\":{\"card\":\"summary_large_image\",\"title\":\"Saferspaces Preise – Ihr individuelles Paket\",\"description\":\"Faire und transparente Preisgestaltung für Ihre Veranstaltung oder Einrichtung. Jetzt Preis berechnen.\",\"image\":\"/assets/images/desktop/de:mockup.webp\",\"creator\":\"@saferspaces\"}},\"business\":{\"title\":\"Sicherheit weiter gedacht\",\"description\":\"Saferspaces ergänzt bestehende Sicherheitskonzepte durch einen innovativen Ansatz, der den Fokus auf Betroffene richtet und sich für ein respektvolles Miteinander einsetzt.\",\"alternates\":{\"canonical\":\"https://www.saferspaces.io/business\",\"types\":{\"de\":\"https://www.saferspaces.io/de/business\",\"en\":\"https://www.saferspaces.io/en/business\"}},\"og\":{\"title\":\"Saferspaces – Sicherheit weiter gedacht\",\"description\":\"Saferspaces ergänzt bestehende Sicherheitskonzepte mit anonymer QR‑Code‑Hilfe für ein respektvolles Miteinander. Erfahren Sie, wie unsere Lösung Betroffene in den Mittelpunkt stellt.\",\"image\":\"/assets/images/desktop/de:mockup.webp\"},\"twitter\":{\"card\":\"summary_large_image\",\"title\":\"Saferspaces – Ihre Lösung für weitergedachte Sicherheit\",\"description\":\"Entdecken Sie, wie Saferspaces bestehende Sicherheitsstrategien mit anonymen QR‑Code‑Lösungen erweitert und Betroffene in den Fokus rückt.\",\"image\":\"/assets/images/desktop/de:mockup.webp\",\"creator\":\"@saferspaces\"}},\"accessibility\":{\"title\":\"Digitale Barrierefreiheit - Saferspaces\",\"description\":\"Informationen zur digitalen Barrierefreiheit der saferspaces Website. Erfahren Sie mehr über unsere Maßnahmen zur Zugänglichkeit und WCAG-Konformität.\",\"alternates\":{\"canonical\":\"https://www.saferspaces.io/accessibility\",\"types\":{\"de\":\"https://www.saferspaces.io/de/accessibility\",\"en\":\"https://www.saferspaces.io/en/accessibility\"}},\"og\":{\"title\":\"Digitale Barrierefreiheit - Saferspaces\",\"description\":\"Informationen zur digitalen Barrierefreiheit der saferspaces Website.\",\"image\":\"/assets/images/desktop/de:mockup.webp\"},\"twitter\":{\"card\":\"summary\",\"title\":\"Digitale Barrierefreiheit - Saferspaces\",\"description\":\"Informationen zur digitalen Barrierefreiheit der saferspaces Website.\"}},\"accessibility.alt\":{\"title\":\"Alt-Text-Generator\",\"description\":\"Hier kannst du Bilder hochladen und automatisch barrierefreie Alternativtexte generieren lassen. Unser Alt-Text-Generator erstellt dir in Sekunden WCAG-konforme Beschreibungen für deine Bilder.\",\"alternates\":{\"canonical\":\"https://www.saferspaces.io/accessibility/alt\",\"types\":{\"de\":\"https://www.saferspaces.io/de/accessibility/alt\",\"en\":\"https://www.saferspaces.io/en/accessibility/alt\"}}},\"agb\":{\"title\":\"Allgemeine Geschäftsbedingungen - Saferspaces\",\"description\":\"Allgemeine Geschäftsbedingungen für die Nutzung der saferspaces Infrastruktur.\",\"alternates\":{\"canonical\":\"https://www.saferspaces.io/agb\",\"types\":{\"de\":\"https://www.saferspaces.io/de/agb\",\"en\":\"https://www.saferspaces.io/en/agb\"}},\"og\":{\"title\":\"Allgemeine Geschäftsbedingungen - Saferspaces\",\"description\":\"Allgemeine Geschäftsbedingungen für die Nutzung der saferspaces Infrastruktur.\",\"image\":\"/assets/images/desktop/de:mockup.webp\"},\"twitter\":{\"card\":\"summary\",\"title\":\"Allgemeine Geschäftsbedingungen - Saferspaces\",\"description\":\"Allgemeine Geschäftsbedingungen für die Nutzung der saferspaces Infrastruktur.\"}},\"imprint\":{\"title\":\"Impressum\",\"description\":\"Impressum und rechtliche Informationen zu saferspaces.\",\"alternates\":{\"canonical\":\"https://www.saferspaces.io/imprint\",\"types\":{\"de\":\"https://www.saferspaces.io/de/imprint\",\"en\":\"https://www.saferspaces.io/en/imprint\"}},\"og\":{\"title\":\"Impressum - Saferspaces\",\"description\":\"Impressum und rechtliche Informationen zu saferspaces.\",\"image\":\"/assets/images/desktop/de:mockup.webp\"},\"twitter\":{\"card\":\"summary\",\"title\":\"Impressum - Saferspaces\",\"description\":\